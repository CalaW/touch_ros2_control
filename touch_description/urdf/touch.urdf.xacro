<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="touch">
  <material name="metal_seamed">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.0 0.0 0.8 1.0"/>
  </material>
  <material name="white">
    <color rgba="1.0 1.0 1.0 1.0"/>
  </material>

  <link name="touch_base">
    <visual>
      <origin xyz="-0.02 0 0" rpy="0 0 -1.57079633"/>
      <geometry>
        <mesh filename="package://touch_description/meshes/base.stl"/>
      </geometry>
      <material name="metal_seamed"/>
    </visual>
  </link>

  <link name="torso">
    <visual>
      <origin xyz="0 0 0.036" rpy="-1.57079633 0 0"/>
      <geometry>
        <mesh filename="package://touch_description/meshes/torso.stl"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>

  <link name="upper_arm">
    <visual>
      <origin xyz="0.0075 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://touch_description/meshes/upper_arm.stl"/>
      </geometry>
      <material name="metal_seamed"/>
    </visual>
  </link>

  <link name="lower_arm">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079633 0 0"/>
      <geometry>
        <mesh filename="package://touch_description/meshes/lower_arm.stl"/>
      </geometry>
      <material name="metal_seamed"/>
    </visual>
  </link>

  <link name="wrist">
    <visual>
      <origin xyz="0 0 0" rpy="3.14159265 0 0"/>
      <geometry>
        <mesh filename="package://touch_description/meshes/wrist.stl"/>
      </geometry>
      <material name="metal_seamed"/>
    </visual>
  </link>

  <link name="tip">
    <visual>
      <origin xyz="0 0 0" rpy="-1.57079633 0 0"/>
      <geometry>
        <mesh filename="package://touch_description/meshes/tip.stl"/>
      </geometry>
      <material name="metal_seamed"/>
    </visual>
  </link>

  <link name="stylus">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079633 1.57079633 0"/>
      <geometry>
        <mesh filename="package://touch_description/meshes/stylus.stl"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>

  <joint name="waist" type="revolute">
    <parent link="touch_base"/>
    <child link="torso"/>
    <origin xyz="0 0 0.09" rpy="0 0 -1.57079633"/>
    <axis xyz="0 0 -1"/>
    <limit lower="-0.95" upper="0.95" velocity="100" effort="5"/>
  </joint>

  <joint name="shoulder" type="revolute">
    <parent link="torso"/>
    <child link="upper_arm"/>
    <origin xyz="-0.0075 0 0.035" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="1.75" velocity="100" effort="5"/>
  </joint>

  <joint name="elbow" type="revolute">
    <parent link="upper_arm"/>
    <child link="lower_arm"/>
    <origin xyz="0.0075 0.13335 0" rpy="-1.57079633 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.78" upper="1.18" velocity="100" effort="5"/>
  </joint>

  <joint name="yaw" type="revolute">
    <parent link="lower_arm"/>
    <child link="wrist"/>
    <origin xyz="0 0.08 0" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="-2.5" upper="2.5" velocity="100" effort="5"/>
  </joint>

  <joint name="pitch" type="revolute">
    <parent link="wrist"/>
    <child link="tip"/>
    <origin xyz="0 0.05335 0" rpy="1.57079633 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.42" upper="1.03" velocity="100" effort="5"/>
  </joint>

  <joint name="roll" type="revolute">
    <parent link="tip"/>
    <child link="stylus"/>
    <origin xyz="0 0.01 0" rpy="3.14159265 3.14159265 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.6" upper="2.6" velocity="100" effort="5"/>
  </joint>

  <link name="HIP"/>
  <link name="tcp"/>

  <joint name="HIP_joint" type="fixed">
    <parent link="stylus"/>
    <child link="HIP"/>
    <origin xyz="0 0.01 0" rpy="0 0 0"/>
  </joint>
  <joint name="tcp_joint" type="fixed">
    <parent link="HIP"/>
    <child link="tcp"/>
    <origin xyz="0 0.038 0" rpy="0 0 0"/>
  </joint>
</robot>
